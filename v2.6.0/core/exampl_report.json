TASK: Si-MOEX-Option-Edge-Analyzer-v4.0

OBJECTIVE: 
Извлечь максимальный опционный edge из realized volatility данных MOEX Si (USD/RUB) 
с строгой иерархией: расчётные поля > label-поля, динамика > статика, 
риск-менеджмент > оптимизация прибыли.

OUTPUT-FORMAT: Structured Markdown with embedded JSON blocks

NOTES-VERSION: 2026-04-17
ENGINE: dual_vol_engine_0.6.0+
SCHEMA: 2.6.0

CORE-PRINCIPLES (нерушимые)

{
  "_priority_hierarchy": {
    "calculation_over_label": "ROC/semivar/spread/gap_quantiles > regime_classification/state_labels/vol_trend",
    "dynamics_over_level": "ROC momentum > absolute vol level",
    "risk_over_return": "Kill conditions > Entry conditions",
    "flip_over_continuous": "Asymmetry flip detection mandatory",
    "forecast_gate_strict": "IV - Forecast_RV >= 1.5pp hard constraint"
  },
  "_absolute_thresholds": {
    "VoV_5d": {"stable": [0, 0.25], "elevated": [0.25, 0.4], "extreme": [0.4, 999]},
    "ROC_5d_short_vol_kill": 30,
    "ROC_5d_long_vol_trigger": -30,
    "gap_freq_high": 7,
    "semivar_ratio": {"absent": [0, 1.1], "mild": [1.1, 1.3], "moderate": [1.3, 1.7], "strong": [1.7, 999]},
    "premium_gate": 1.5
  }
}

STEP-1: REGIME-DIAGNOSTICS

{
  "_step": 1,
  "_max_sentences": 5,
  "level_classification": {
    "benchmark": "F1_YZ_20d vs F1_YZ_60d vs F0_YZ_60d",
    "proxy_rule": "if F1_YZ_250d == null → use F0_YZ_250d, explicitly note",
    "classes": ["low", "normal", "elevated", "crisis", "elevated_crushing"],
    "elevated_crushing_condition": "YZ_20d_ROC_20d > 0 AND ROC_5d << 0"
  },
  "dynamics_analysis": {
    "ROC_horizons": ["5d", "10d", "20d"],
    "ratio_YZ_5d_20d": {"compression": [0, 0.75], "stable": [0.75, 1.1], "spike": [1.1, 999]},
    "contradiction_resolution": "ROC fields override regime_classification.dynamics"
  },
  "VoV_regime": {
    "classification": "use _absolute_thresholds.VoV_5d",
    "structure_check": "VoV_5d vs VoV_20d vs VoV_60d",
    "vomma_risk_trigger": "VoV_5d > 0.40 → explicit warning block",
    "cross_contract": "F1_VoV >> F2_VoV = front-specific stress"
  },
  "contradiction_registry": {
    "required": true,
    "fields": ["regime_classification", "state_labels", "momentum_5d_vs_20d", "ROC fields"],
    "resolution": "calculation fields priority with explicit note"
  }
}

STEP-2: SAMUELSON-CONTINUITY

{
  "_step": 2,
  "_max_sentences": 4,
  "DTE_assessment": {
    "primary": "F1 days_to_expiry",
    "samuelson_status_check": "normal_for_dte confirmed by YZ_20d/YZ_60d ratio",
    "z_score_rule": "z in [-2, 2] never called extreme",
    "short_table": {
      "applicability": "only if holding to DTE < 10",
      "reliability_note": "n=10-11, directional hint only",
      "null_DTE": "skip, do not interpolate"
    }
  },
  "F0_F1_continuity": {
    "vol_change": "F0_YZ_20d vs F1_YZ_20d in pp",
    "asymmetry_calculation": {
      "F0_ratio": "F0_semivar_down_20d / F0_semivar_up_20d",
      "F1_ratio": "F1_semivar_down_20d / F1_semivar_up_20d",
      "classification": ["continuous_downside", "continuous_upside", "flip", "stable"]
    },
    "flip_implication": "flip + elevated vol = double confirmation F1 bias"
  }
}

