STEP-4: ASYMMETRY-FLIP-ANALYSIS (Enhanced)

{
  "_step": 4,
  "_critical": true,
  "calculation": {
    "F0_20d": "F0_semivar_down_20d / F0_semivar_up_20d",
    "F1_20d": "F1_semivar_down_20d / F1_semivar_up_20d",
    "F1_5d": "F1_semivar_down_5d / F1_semivar_up_5d"
  },
  "classification": {
    "flip_upside_to_downside": "F0_ratio < 0.9 AND F1_ratio > 1.1",
    "flip_downside_to_upside": "F0_ratio > 1.1 AND F1_ratio < 0.9",
    "continuous": "both ratios same side of 1.0",
    "escalation": "same direction, F1_ratio > F0_ratio by >0.2"
  },
  "strategic_implications": {
    "flip_downside": "strongest BWB put signal",
    "flip_upside": "strongest BWB call signal", 
    "continuous_downside": "confirmed trend",
    "escalation": "increasing conviction"
  }
}

